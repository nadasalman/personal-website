---
layout: default
---
{% assign cv_feature_enabled = site.al_folio.features.cv.enabled | default: true %}

{% if site.plugins contains 'al_folio_cv' and cv_feature_enabled %}
  {% al_folio_cv_render %}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var header = document.querySelector('.post-header');
      if (!header) return;
      var bar = document.createElement('div');
      bar.style.cssText = 'display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;margin-top:-1rem;';
      bar.innerHTML =
        '<a href="{{ "/assets/pdf/nada_salman_cv.pdf" | relative_url }}" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.3rem 0.75rem;border:1px solid var(--global-theme-color);border-radius:4px;color:var(--global-theme-color);font-size:0.85rem;text-decoration:none;">' +
          '<i class="fa-solid fa-file-pdf"></i> Dossier Technique (FR)' +
        '</a>' +
        '<a href="{{ "/assets/pdf/nada_salman_resume.pdf" | relative_url }}" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:0.35rem;padding:0.3rem 0.75rem;border:1px solid var(--global-theme-color);border-radius:4px;color:var(--global-theme-color);font-size:0.85rem;text-decoration:none;">' +
          '<i class="fa-solid fa-file-lines"></i> Résumé une page (FR)' +
        '</a>';
      header.insertAdjacentElement('afterend', bar);
    });
  </script>
{% else %}
  <div class="post">
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-description">CV rendering is unavailable. Enable the <code>al_folio_cv</code> plugin.</p>
    </header>
  </div>
{% endif %}
